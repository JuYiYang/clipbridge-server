{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "clipbridge-server",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-11",
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
