{
  "name": "clipbridge-server",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Workers + D1 sync backend for ClipBridge.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:create": "wrangler d1 create clipbridge",
    "db:migrate:local": "wrangler d1 migrations apply clipbridge --local",
    "db:migrate:remote": "wrangler d1 migrations apply clipbridge --remote"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "wrangler": "^4.24.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
